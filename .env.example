# Copy to .env and fill in. .env is gitignored.

# Google AI Studio key for Gemini Live (https://aistudio.google.com/live)
GEMINI_API_KEY=

# Gemini Live model id (realtime voice). Override if you have access to a newer one.
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# Shared secret the phone client must present on the WebSocket (any random string).
VOXA_AUTH_TOKEN=

# Gates the /admin-api/* admin dashboard. Leave unset to disable the dashboard
# entirely. Should be a long random value, e.g.:
#   python3 -c "import secrets;print(secrets.token_hex(32))"
VOXA_ADMIN_TOKEN=

# Optional: USD prices for the top-up StoreKit products, used by the admin
# dashboard's revenue estimate. Each defaults to $0.00 until set here.
# VOXA_PRICE_VOXA_TOPUP_SMALL=4.99
# VOXA_PRICE_VOXA_TOPUP_MEDIUM=9.99
# VOXA_PRICE_VOXA_TOPUP_LARGE=19.99

# Host/port the laptop server binds to.
VOXA_HOST=127.0.0.1
VOXA_PORT=8787

# Anthropic auth: the claude-agent-sdk reuses your existing Claude Code login by
# default. Set this only if you want to use an API key instead.
# ANTHROPIC_API_KEY=

# APNs (VoIP push) for agent-initiated calls. From the Apple Developer portal.
# Leave blank to disable push/calls (the app still works as a voice client).
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=space.voxa.app
# true for Xcode/dev-signed (sideloaded) builds; false for TestFlight/App Store.
APNS_SANDBOX=true
